# At least one AI provider key is required.
# The backend auto-detects which to use — ANTHROPIC_API_KEY takes priority if both are set.

# Option A: Anthropic (Claude Haiku)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Option B: OpenAI (GPT-4o mini)
# OPENAI_API_KEY=your-openai-api-key-here

# PostgreSQL (optional — for production with pgvector)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=swiftplumbing
# DB_USER=postgres
# DB_PASSWORD=your_password_here
